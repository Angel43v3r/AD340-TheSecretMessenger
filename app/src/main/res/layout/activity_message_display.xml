<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MessageDisplayActivity">

    <!-- Secret Message Title -->
    <TextView
        android:id="@+id/secretMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/secretMessage"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/title"
        android:layout_marginTop="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- To display the incoming string -->
    <TextView
        android:id="@+id/decodedMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textAlignment="center"
        android:padding="16dp"
        android:background="@color/transparent"
        android:textColor="@color/white"
        android:layout_marginVertical="24dp"
        app:layout_constraintTop_toBottomOf="@id/secretMessage"/>

    <!-- Button labeled "Back" (to return to the first screen) -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="@string/back"
        app:layout_constraintTop_toBottomOf="@id/decodedMessage"/>

</androidx.constraintlayout.widget.ConstraintLayout>